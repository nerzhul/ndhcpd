#!/bin/sh

# PROVIDE: ndhcpd
# REQUIRE: NETWORKING
# KEYWORD: shutdown

. /etc/rc.subr

name="ndhcpd"
rcvar="ndhcpd_enable"
desc="DHCP Server Daemon"

load_rc_config $name

: ${ndhcpd_enable:="NO"}
: ${ndhcpd_user:="root"}
: ${ndhcpd_group:="wheel"}
: ${ndhcpd_log:="info"}

command="/usr/local/bin/ndhcpd"
command_interpreter=""
pidfile="/var/run/${name}.pid"

ndhcpd_env="RUST_LOG=${ndhcpd_log}"

command_args=""

load_rc_config $name
run_rc_command "$1"
